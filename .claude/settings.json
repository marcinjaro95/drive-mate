{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix . --quiet || true",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "npx tsc --noEmit",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
